# --- core ---
SECRET_KEY=change-me-to-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- logging ---
# DEBUG shows LLM prompt/response previews. INFO is good for prod.
LOG_LEVEL=INFO
LIB_LOG_LEVEL=WARNING
# Set true in production for structured JSON logs (works with Better Stack / Axiom / Loki).
LOG_JSON=false
# Optional: also write logs to a file (e.g. /var/log/cvforge.log)
# LOG_FILE=cvforge.log
# Comma-separated emails granted admin/support access (audit search + manual credit adjust).
ADMIN_EMAILS=

# --- database ---
# SQLite default (zero setup, local dev / tests).
# For production (Vercel), use Supabase Postgres via the Supavisor
# TRANSACTION-MODE POOLER on port 6543 (NOT the direct 5432 connection -
# serverless functions open/close connections per request and will exhaust
# a direct Postgres connection limit almost immediately).
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./cvforge.db

# --- LLM providers ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_PRO=gemini-3.5-flash

# --- pipeline role assignment ---
# which provider drafts the tailored CV / cover letter, which critiques.
# values: deepseek | gemini
DRAFTER_PROVIDER=gemini
CRITIC_PROVIDER=deepseek

# --- generation pipeline limits ---
# "fast": every LLM call uses the non-pro/flash model, ~5-25s/call. Required on
# Vercel Hobby (60s function limit) since each generation step is its own request.
# "quality": tailor/critique may use pro models - DO NOT use on Vercel Hobby,
# pro-model calls can exceed 60s.
GENERATION_TIER=fast
# cap output tokens per LLM call (applies to every provider).
LLM_MAX_TOKENS=4000
# per-call HTTP timeout in seconds, so a stuck provider fails fast with a
# clear 502/504 instead of the platform killing the function mid-call.
LLM_TIMEOUT_S=50

# if the primary provider above returns an error (e.g. 503 overloaded) after
# its own retries, the request is retried once on this provider. empty = disabled.
DRAFTER_FALLBACK_PROVIDER=deepseek
CRITIC_FALLBACK_PROVIDER=gemini

# --- billing / credits (tune these to set your prices & profit margin) ---
BILLING_ENABLED=true
# Frontend base URL: Polar checkout return URL AND the CORS allow-origin for
# the API (in addition to localhost). Set to your frontend Vercel domain in prod,
# e.g. https://cvforge.vercel.app
APP_URL=http://localhost:5173
CREDITS_PER_GENERATION=1
# free model: "trial" (one-time credits on signup) or "forever_free" (monthly refill)
FREE_TIER_MODE=trial
FREE_TRIAL_CREDITS=10
FREE_MONTHLY_CREDITS=5
# --- ATS score guarantee ---
# if a generation scores below the plan's min_ats_score (see BILLING_PLANS_JSON below),
# the pipeline auto re-tailors and re-scores (free of extra credit charge) up to this
# many total passes before giving up.
ATS_GUARANTEE_MAX_ITERATIONS=3
# guarantee for plans that don't set min_ats_score (e.g. free/trial). 0 = no guarantee.
DEFAULT_MIN_ATS_SCORE=0
# YOUR estimated LLM cost per generation — used to show your margin per plan
COST_PER_GENERATION_USD=0.02
# --- Polar payment gateway (Merchant of Record: handles Sri Lanka payouts + PCI) ---
BILLING_PROVIDER=polar
# 1) Polar > Settings > create an Organization Access Token. Server-side ONLY — never expose to the browser.
POLAR_ACCESS_TOKEN=
# 2) Polar > Webhooks > add endpoint (URL = https://YOUR_BACKEND/billing/webhook), copy its signing secret here.
POLAR_WEBHOOK_SECRET=
# 3) "sandbox" while testing (sandbox.polar.sh + a sandbox token), "production" when live.
POLAR_SERVER=sandbox
# Where Polar returns the buyer after payment (your frontend).
POLAR_SUCCESS_URL=http://localhost:5173/billing?status=success
# 4) Create products in Polar (one-time and/or subscription). Put each product's ID in polar_product_id.
#    price_usd/credits = display + how many credits a payment grants (keep price in sync with the Polar product).
#    recurring=true for subscription products.
# min_ats_score: guaranteed minimum ATS score for that plan (0 = no guarantee).
BILLING_PLANS_JSON=[{"id":"starter","name":"Starter","price_usd":9,"credits":100,"polar_product_id":"","recurring":false,"min_ats_score":80},{"id":"pro","name":"Pro Monthly","price_usd":29,"credits":500,"polar_product_id":"","recurring":true,"min_ats_score":85}]
